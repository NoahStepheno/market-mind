# AI Parser (GLM-5)
GLM_API_KEY=
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-5-plus
FRONTEND_AUTH_CALLBACK_URL=http://localhost:5173/auth/callback

# Alarms realtime pipeline (ingest + evaluator + outbox relay + notify)
# ALARM_PIPELINE_ENABLED=false
# INTERNAL_ALARM_INGEST_TOKEN=replace-with-long-random-token
# ALARM_INGEST_QUEUE_MAX=10000
# ALARM_NOTIFY_QUEUE_MAX=1000
# ALARM_MAX_CONDITION_LEAVES=5

# Vector search (Qdrant + DashScope embeddings)
QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=recipes_v1
DASHSCOPE_EMBEDDING_MODEL=qwen3-vl-embedding
DASHSCOPE_EMBEDDING_DIMENSION=1024
# Native DashScope API root (required for qwen3-vl-embedding; Singapore: https://dashscope-intl.aliyuncs.com/api/v1)
# DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# DASHSCOPE_API_KEY=   # optional if ALI_BAILIAN_EMBEDDING_API_KEY is set
# ALI_BAILIAN_EMBEDDING_API_KEY=

# Menu LLM (DashScope OpenAI-compatible chat; same API key as embeddings)
# DASHSCOPE_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_CHAT_MODEL=qwen-plus
# MENU_LLM_MAX_TOOL_ROUNDS=6
# MENU_RECOMMEND_TRACE_STDOUT=1
