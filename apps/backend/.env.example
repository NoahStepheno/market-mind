GOOGLE_CLIENT_SECRET=
JWT_SECRET=replace-with-another-long-random-secret
JWT_ISSUER=market-backend
JWT_AUDIENCE=market-client
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600
